#!/usr/bin/env python3
import argparse
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from datetime import datetime
from pathlib import Path
from typing import Dict, List, Optional, Tuple


@dataclass
class RepoSpec:
    name: str
    path: Path


@dataclass
class CommitInfo:
    repo_idx: int
    repo_name: str
    repo_path: Path
    commit: str
    author_time: int
    author_name: str
    author_email: str
    author_date_iso: str
    committer_name: str
    committer_email: str
    committer_date_iso: str
    message: str


class GitUnionError(Exception):
    pass


# Global verbose flag for logging git commands
_verbose = False


def run_git(args: List[str], cwd: Path, check: bool = True, capture: bool = True) -> subprocess.CompletedProcess:
    cmd = ["git", *args]
    if _verbose:
        print(f"[git] cd {cwd} && git {' '.join(args)}", file=sys.stderr)
    return subprocess.run(
        cmd,
        cwd=str(cwd),
        check=check,
        text=True,
        capture_output=capture,
    )


def run_git_bytes(args: List[str], cwd: Path) -> subprocess.CompletedProcess:
    cmd = ["git", *args]
    if _verbose:
        print(f"[git] cd {cwd} && git {' '.join(args)}", file=sys.stderr)
    return subprocess.run(cmd, cwd=str(cwd), check=True, capture_output=True)


def parse_repo_arg(raw: str) -> Tuple[str, str]:
    if "=" in raw:
        name, path = raw.split("=", 1)
        name = name.strip()
        path = path.strip()
        if not name:
            raise GitUnionError(f"Invalid repo mapping '{raw}': name is empty")
        if not path:
            raise GitUnionError(f"Invalid repo mapping '{raw}': path is empty")
        return name, path
    p = raw.strip()
    if not p:
        raise GitUnionError("Empty repo argument")
    return os.path.basename(os.path.normpath(p)), p


def ensure_git_repo(path: Path) -> None:
    if not path.exists():
        raise GitUnionError(f"Repository path does not exist: {path}")
    try:
        run_git(["rev-parse", "--git-dir"], cwd=path)
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or "").strip()
        raise GitUnionError(f"Not a git repository: {path}\n{stderr}") from exc


def collect_commits(spec: RepoSpec, repo_idx: int) -> List[CommitInfo]:
    revs = run_git(["rev-list", "--reverse", "HEAD"], cwd=spec.path).stdout.splitlines()
    items: List[CommitInfo] = []
    for commit in revs:
        fmt = "%at%x00%an%x00%ae%x00%aI%x00%cn%x00%ce%x00%cI%x00%B"
        out = run_git(["show", "-s", f"--format={fmt}", commit], cwd=spec.path).stdout
        parts = out.split("\x00", 7)
        if len(parts) != 8:
            raise GitUnionError(f"Unexpected git show format while reading {spec.name}:{commit}")
        author_time = int(parts[0].strip())
        items.append(
            CommitInfo(
                repo_idx=repo_idx,
                repo_name=spec.name,
                repo_path=spec.path,
                commit=commit,
                author_time=author_time,
                author_name=parts[1].strip(),
                author_email=parts[2].strip(),
                author_date_iso=parts[3].strip(),
                committer_name=parts[4].strip(),
                committer_email=parts[5].strip(),
                committer_date_iso=parts[6].strip(),
                message=parts[7],
            )
        )
    return items


def schedule_commits(per_repo: List[List[CommitInfo]], do_sort: bool) -> List[CommitInfo]:
    if not do_sort:
        merged: List[CommitInfo] = []
        for seq in per_repo:
            merged.extend(seq)
        return merged

    positions = [0 for _ in per_repo]
    out: List[CommitInfo] = []
    while True:
        candidates: List[CommitInfo] = []
        for idx, seq in enumerate(per_repo):
            pos = positions[idx]
            if pos < len(seq):
                candidates.append(seq[pos])
        if not candidates:
            break
        # Preserve each repo's order by only considering each queue head.
        # Tie-break with repo index for deterministic output.
        chosen = min(candidates, key=lambda c: (c.author_time, c.repo_idx))
        out.append(chosen)
        positions[chosen.repo_idx] += 1
    return out


def parse_diff_tree_z(raw: bytes) -> List[Tuple[str, str, str, str, Optional[str]]]:
    # Returns tuples: (mode, status, path_a, dst_hash, path_b_for_rename_or_copy)
    # Format: :src_mode dst_mode src_hash dst_hash status\0path\0...
    tokens = raw.split(b"\x00")
    if tokens and tokens[-1] == b"":
        tokens = tokens[:-1]
    i = 0
    out: List[Tuple[str, str, str, str, Optional[str]]] = []
    while i < len(tokens):
        header = tokens[i].decode("utf-8", errors="replace")
        i += 1
        if not header:
            continue
        # Parse header: :src_mode dst_mode src_hash dst_hash status
        if not header.startswith(":"):
            raise GitUnionError(f"Malformed diff-tree header: {header}")
        parts = header[1:].split()
        if len(parts) != 5:
            raise GitUnionError(f"Unexpected diff-tree header format: {header}")
        src_mode, dst_mode, src_hash, dst_hash, status = parts
        # Use dst_mode (the resulting mode after the change)
        mode = dst_mode
        
        if status in ("R", "C"):
            if i + 1 >= len(tokens):
                raise GitUnionError("Malformed diff-tree -z output for rename/copy")
            old_path = tokens[i].decode("utf-8", errors="surrogateescape")
            new_path = tokens[i + 1].decode("utf-8", errors="surrogateescape")
            i += 2
            out.append((mode, status, old_path, dst_hash, new_path))
        else:
            if i >= len(tokens):
                raise GitUnionError("Malformed diff-tree -z output")
            path = tokens[i].decode("utf-8", errors="surrogateescape")
            i += 1
            out.append((mode, status, path, dst_hash, None))
    return out


def safe_relpath(path: str) -> Path:
    p = Path(path)
    if p.is_absolute():
        raise GitUnionError(f"Absolute path encountered in commit diff: {path}")
    norm = Path(os.path.normpath(path))
    if str(norm).startswith(".."):
        raise GitUnionError(f"Path escapes repo root in commit diff: {path}")
    return norm


def write_file_from_commit(repo_path: Path, commit: str, src_path: str, dest_path: Path, 
                           repo_name: Optional[str] = None) -> None:
    try:
        blob = run_git_bytes(["show", f"{commit}:{src_path}"], cwd=repo_path).stdout
    except subprocess.CalledProcessError as exc:
        stderr = (exc.stderr or b"").decode("utf-8", errors="replace").strip()
        raise GitUnionError(f"Failed reading blob {commit}:{src_path}\n{stderr}") from exc
    
    # Skip .gitmodules from source - we'll generate it based on actual gitlinks
    if src_path == ".gitmodules" and repo_name:
        return  # Don't write the source .gitmodules
        # Translate paths by prepending repo_name
        # The paths in .gitmodules should match the actual gitlink locations
        blob_str = blob.decode('utf-8')
        lines = blob_str.split('\n')
        
        # Parse into sections and translate paths
        sections = []
        current_section = None
        current_lines = []
        
        for line in lines:
            stripped = line.strip()
            if stripped.startswith('[submodule'):
                if current_section is not None:
                    sections.append(current_lines)
                current_section = stripped
                current_lines = [line]
            else:
                if current_section is not None:
                    current_lines.append(line)
        if current_section is not None:
            sections.append(current_lines)
        
        # Deduplicate by path and translate
        seen_paths = set()
        new_sections = []
        for section_lines in sections:
            # Find path in this section
            path_line_idx = None
            old_path = None
            for i, line in enumerate(section_lines):
                if line.strip().startswith('path = '):
                    path_line_idx = i
                    old_path = line.strip().split('=', 1)[1].strip()
                    break
            
            if path_line_idx is not None and old_path:
                # Prepend repo name to get the actual path in monorepo
                new_path = f"{repo_name}/{old_path}"
                
                # Skip duplicates
                if new_path in seen_paths:
                    continue
                
                seen_paths.add(new_path)
                
                # Translate the path line
                section_lines[path_line_idx] = f"\tpath = {new_path}"
                new_sections.append(section_lines)
        
        # Flatten
        all_lines = []
        for section_lines in new_sections:
            all_lines.extend(section_lines)
        result = '\n'.join(all_lines)
        # Ensure trailing newline
        if not result.endswith('\n'):
            result += '\n'
        blob = result.encode('utf-8')
    
    dest_path.parent.mkdir(parents=True, exist_ok=True)
    with open(dest_path, "wb") as fh:
        fh.write(blob)


def apply_commit_into_monorepo(mono_dir: Path, info: CommitInfo, verbose: bool = False) -> bool:
    # Use diff-tree without --name-status to get file modes (to detect submodules)
    status_raw = run_git_bytes(
        ["diff-tree", "--root", "--no-commit-id", "-r", "-z", info.commit],
        cwd=info.repo_path,
    ).stdout
    changes = parse_diff_tree_z(status_raw)
    repo_prefix = mono_dir / info.repo_name
    touched = False
    
    # Collect submodule operations to apply after git add -A
    submodule_ops: List[Tuple[str, str, str]] = []  # (op, path, hash)

    for mode, code, p1, dst_hash, p2 in changes:
        # Handle submodules (mode 160000) - collect for later
        if mode == "160000":
            if verbose:
                print(f"[submodule] {info.repo_name} {code} {p1} @ {dst_hash[:12]}")
            
            if code == "D":
                submodule_ops.append(("D", p1, ""))
            else:
                rel_path = p1 if p2 is None else p2
                submodule_ops.append(("A", rel_path, dst_hash))
            continue
        
        if code == "D":
            dst = repo_prefix / safe_relpath(p1)
            if dst.exists():
                if dst.is_dir():
                    shutil.rmtree(dst)
                else:
                    dst.unlink()
                touched = True
            continue

        if code == "R":
            old_dst = repo_prefix / safe_relpath(p1)
            if old_dst.exists():
                if old_dst.is_dir():
                    shutil.rmtree(old_dst)
                else:
                    old_dst.unlink()
                touched = True
            assert p2 is not None
            new_dst = repo_prefix / safe_relpath(p2)
            write_file_from_commit(info.repo_path, info.commit, p2, new_dst, info.repo_name)
            touched = True
            continue

        if code == "C":
            assert p2 is not None
            dst = repo_prefix / safe_relpath(p2)
            write_file_from_commit(info.repo_path, info.commit, p2, dst, info.repo_name)
            touched = True
            continue

        # A, M, T and any unknown non-delete status: materialize commit's file content.
        dst = repo_prefix / safe_relpath(p1)
        write_file_from_commit(info.repo_path, info.commit, p1, dst, info.repo_name)
        touched = True

    if not touched:
        if verbose:
            print(f"[skip] {info.repo_name} {info.commit[:12]} empty/no-op")
        return False

    # Before git add -A, save existing gitlinks from HEAD
    existing_gitlinks: Dict[str, str] = {}
    try:
        head_tree = run_git(["ls-tree", "-r", "HEAD", "--", info.repo_name], cwd=mono_dir).stdout
        for line in head_tree.splitlines():
            parts = line.split()
            if len(parts) >= 4 and parts[0] == "160000":
                mode, type_, hash_, path = parts[0], parts[1], parts[2], parts[3]
                existing_gitlinks[path] = hash_
    except subprocess.CalledProcessError:
        pass  # No HEAD yet or no gitlinks
    
    run_git(["add", "-A"], cwd=mono_dir, capture=True)
    
    # Preserve gitlinks that still exist in the source repo at the same path
    for path, hash_ in existing_gitlinks.items():
        # Check if this path still exists in the source repo at this commit
        rel_path = path[len(str(info.repo_name)) + 1:]  # Remove "gmodsrepo/"
        try:
            result = run_git(["ls-tree", info.commit, "--", rel_path], cwd=info.repo_path, check=False)
            if result.returncode == 0 and result.stdout.strip():
                # Path still exists, preserve the gitlink
                subprocess.run(
                    ["git", "update-index", "--add", "--cacheinfo", "160000", hash_, path],
                    cwd=str(mono_dir),
                    check=False,
                    capture_output=True,
                )
                if verbose:
                    print(f"  -> preserved gitlink at {path}")
        except subprocess.CalledProcessError:
            pass  # Path doesn't exist, don't preserve
    
    # Now apply submodule operations for this commit
    for op, rel_path, subm_hash in submodule_ops:
        if op == "D":
            dst = repo_prefix / safe_relpath(rel_path)
            subprocess.run(
                ["git", "rm", "-f", "--cached", str(dst)],
                cwd=str(mono_dir),
                check=False,
                capture_output=True,
            )
            if verbose:
                print(f"  -> removed gitlink at {rel_path}")
        else:
            dst = repo_prefix / safe_relpath(rel_path)
            # Prepend repo prefix to get the full path in monorepo
            # But use relative path from monorepo root for git update-index
            rel_full_path = str(info.repo_name / safe_relpath(rel_path))
            (mono_dir / rel_full_path).parent.mkdir(parents=True, exist_ok=True)
            result = subprocess.run(
                ["git", "update-index", "--add", "--cacheinfo", "160000", subm_hash, rel_full_path],
                cwd=str(mono_dir),
                check=False,
                capture_output=True,
                text=True,
            )
            if result.returncode != 0:
                if verbose:
                    print(f"  ! Failed to add gitlink: {result.stderr.strip()}")
            else:
                touched = True
                if verbose:
                    print(f"  -> gitlink {subm_hash[:12]} at {rel_full_path}")
    
    # Generate .gitmodules at monorepo ROOT (not inside repo subdir)
    # .gitmodules must be at repository root for git submodule to find it
    gitmodules_path = mono_dir / ".gitmodules"
    gitmodules_content = []
    
    # Get all current gitlinks for this repo from index
    try:
        ls_output = subprocess.run(
            ["git", "ls-files", "-s", "--", info.repo_name],
            cwd=str(mono_dir),
            check=True,
            capture_output=True,
            text=True
        ).stdout
        
        seen_paths = set()
        for line in ls_output.splitlines():
            parts = line.split()
            if len(parts) >= 4 and parts[0] == "160000":
                full_path = parts[3]  # e.g., "gmodsrepo/boost_assert"
                if full_path in seen_paths:
                    continue
                seen_paths.add(full_path)
                
                hash_ = parts[1]
                rel_path = full_path[len(str(info.repo_name)) + 1:]  # Remove "gmodsrepo/"
                
                # Determine URL based on path patterns
                if "boost" in rel_path.lower():
                    name = rel_path.split("/")[-1].replace("boost_", "")
                    url = f"https://github.com/boostorg/{name}.git"
                elif "zash" in rel_path.lower():
                    url = "git@github.com:lenik/zash.git"
                else:
                    url = "TODO"
                
                section_name = rel_path.replace("/", "_").replace("-", "_")
                gitmodules_content.append(f'[submodule "{section_name}"]')
                gitmodules_content.append(f'\tpath = {full_path}')
                gitmodules_content.append(f'\turl = {url}')
        
        if gitmodules_content:
            gitmodules_path.parent.mkdir(parents=True, exist_ok=True)
            with open(gitmodules_path, "w") as f:
                f.write('\n'.join(gitmodules_content) + '\n')
            
            # Stage the .gitmodules file
            subprocess.run(
                ["git", "add", str(gitmodules_path)],
                cwd=str(mono_dir),
                check=False,
                capture_output=True,
            )
            touched = True
    except subprocess.CalledProcessError:
        pass
    
    try:
        parent = run_git(["rev-parse", "--verify", "HEAD"], cwd=mono_dir, check=False).returncode == 0
        if parent:
            diff = run_git(["diff", "--cached", "--quiet"], cwd=mono_dir, check=False)
            if diff.returncode == 0:
                if verbose:
                    print(f"[skip] {info.repo_name} {info.commit[:12]} no staged changes")
                return False
    except subprocess.CalledProcessError:
        pass

    env = os.environ.copy()
    env["GIT_AUTHOR_NAME"] = info.author_name
    env["GIT_AUTHOR_EMAIL"] = info.author_email
    env["GIT_AUTHOR_DATE"] = info.author_date_iso
    env["GIT_COMMITTER_NAME"] = info.committer_name
    env["GIT_COMMITTER_EMAIL"] = info.committer_email
    env["GIT_COMMITTER_DATE"] = info.committer_date_iso

    msg = info.message.rstrip("\n") + "\n"
    subprocess.run(
        ["git", "commit", "--allow-empty-message", "-m", msg],
        cwd=str(mono_dir),
        check=True,
        env=env,
        text=True,
        capture_output=not verbose,
    )
    if verbose:
        t = datetime.fromtimestamp(info.author_time).isoformat(sep=" ", timespec="seconds")
        print(f"[commit] {info.repo_name} {info.commit[:12]} @{t}")
    return True


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="git-union",
        description="Merge several git repos into one monorepo, placing each repo under a subdirectory.",
    )
    p.add_argument("-s", "--sort", action="store_true", help="Sort by author time while preserving per-repo order")
    p.add_argument("-v", "--verbose", action="store_true", help="Verbose output")
    p.add_argument("-q", "--quiet", action="store_true", help="Quiet mode")
    p.add_argument("--version", action="version", version="git-union 0.1.0")
    p.add_argument("mono_dir", help="Output monorepo directory (must not already exist)")
    p.add_argument("repos", nargs="+", help="Repo path or name=repo_path")
    return p


def main(argv: List[str]) -> int:
    global _verbose
    parser = build_parser()
    args = parser.parse_args(argv)
    if args.verbose and args.quiet:
        raise GitUnionError("Cannot use both --verbose and --quiet")
    
    # Set global verbose flag for git command logging
    _verbose = args.verbose and not args.quiet

    specs: List[RepoSpec] = []
    seen_names: Dict[str, Path] = {}
    for raw in args.repos:
        name, path_str = parse_repo_arg(raw)
        path = Path(path_str).resolve()
        ensure_git_repo(path)
        if name in seen_names:
            raise GitUnionError(f"Duplicate subdir name '{name}' for {path} and {seen_names[name]}")
        seen_names[name] = path
        specs.append(RepoSpec(name=name, path=path))

    mono_dir = Path(args.mono_dir).resolve()
    if mono_dir.exists():
        raise GitUnionError(f"Output directory already exists: {mono_dir}")
    mono_dir.mkdir(parents=True, exist_ok=False)
    run_git(["init"], cwd=mono_dir)

    if not args.quiet:
        print(f"Initialized monorepo at {mono_dir}")

    per_repo_commits: List[List[CommitInfo]] = []
    for idx, spec in enumerate(specs):
        commits = collect_commits(spec, idx)
        per_repo_commits.append(commits)
        if args.verbose and not args.quiet:
            print(f"[repo] {spec.name}: {len(commits)} commits")

    schedule = schedule_commits(per_repo_commits, args.sort)
    if args.verbose and not args.quiet:
        print(f"[plan] applying {len(schedule)} commits")

    written = 0
    for item in schedule:
        did = apply_commit_into_monorepo(mono_dir, item, verbose=(args.verbose and not args.quiet))
        if did:
            written += 1

    if not args.quiet:
        print(f"Done. Wrote {written} commits into {mono_dir}")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv[1:]))
    except GitUnionError as exc:
        print(f"error: {exc}", file=sys.stderr)
        raise SystemExit(2)
